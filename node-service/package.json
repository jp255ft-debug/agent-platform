{
  "name": "@agent-platform/node-service",
  "version": "0.1.0",
  "description": "Node service for GPU telemetry collection and DePIN provider health reporting",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "proto:generate": "protoc --ts_out src/generated --proto_path src/proto src/proto/telemetry.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "kafkajs": "^2.2.4",
    "protobufjs": "^7.2.6",
    "systeminformation": "^5.22.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
