# =============================================================================
# Agent Platform — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your local environment.
#   cp .env.example .env
# =============================================================================

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agent_platform
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=agent-platform-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

# ─── Backend (FastAPI) ────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Blockchain (Base Sepolia) ────────────────────────────────────────────────
# Default: Base Sepolia testnet. Change to mainnet for production.
WEB3_PROVIDER_URL=https://sepolia.base.org
CHAIN_ID=84532

# Contract addresses (deploy first, then update here)
AGENT_DELEGATION_CONTRACT=0x0000000000000000000000000000000000000000
PAYMENT_VERIFIER_CONTRACT=0x0000000000000000000000000000000000000000
REPUTATION_SBT_CONTRACT=0x0000000000000000000000000000000000000000

# Private key for the platform operator (used for on-chain operations)
# WARNING: Never commit this to version control!
OPERATOR_PRIVATE_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=100

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=8001
ENABLE_METRICS=true

# ─── TimescaleDB (optional analytics) ─────────────────────────────────────────
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5433
TIMESCALE_DB=agent_analytics
TIMESCALE_USER=agent_user
TIMESCALE_PASSWORD=changeme_in_production
