{
  "__inputs": [],
  "__requires": [],
  "title": "Agent Platform - DePIN Procurement Overview",
  "uid": "agent-platform-overview",
  "version": 2,
  "schemaVersion": 36,
  "tags": ["agent-platform", "depin", "procurement", "overview"],
  "timezone": "browser",
  "editable": true,
  "refresh": "5m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "postgres",
        "current": {
          "value": "PostgreSQL"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "Total Value Settled (TVS)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT COALESCE(SUM((data->>'amount_micro_usdc')::numeric) / 1000000, 0) AS value FROM events WHERE event_type IN ('PaymentVerified', 'BillingSessionSettled') AND occurred_at >= NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "usd",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "green", "value": 100}
            ]
          }
        }
      }
    },
    {
      "title": "Active GPU Leases",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT COUNT(DISTINCT aggregate_id) AS value FROM events WHERE event_type = 'BillingSessionStarted' AND occurred_at >= NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 10}
            ]
          }
        }
      }
    },
    {
      "title": "Bad Debt Prevented",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT COALESCE(SUM((data->>'amount_usdc')::numeric), 0) AS value FROM events WHERE data->>'kill_switch_triggered' = 'true' AND occurred_at >= NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "usd",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        }
      }
    },
    {
      "title": "Active Delegations (EIP-7702)",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT COUNT(*) AS value FROM events WHERE event_type = 'AgentDelegated' AND occurred_at >= NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 5}
            ]
          }
        }
      }
    },
    {
      "title": "Kill-Switch Events (24h)",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT COUNT(*) AS value FROM events WHERE data->>'kill_switch_triggered' = 'true' AND occurred_at >= NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "title": "TVS Over Time (USDC)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT DATE_TRUNC('hour', occurred_at) AS time, COALESCE(SUM((data->>'amount_micro_usdc')::numeric) / 1000000, 0) AS tvs FROM events WHERE event_type IN ('PaymentVerified', 'BillingSessionSettled') AND occurred_at >= NOW() - INTERVAL '7 days' GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "usd",
          "custom": {"lineInterpolation": "smooth"}
        }
      }
    },
    {
      "title": "Active GPU Leases Over Time",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT DATE_TRUNC('hour', occurred_at) AS time, COUNT(DISTINCT aggregate_id) AS active_leases FROM events WHERE event_type = 'BillingSessionStarted' AND occurred_at >= NOW() - INTERVAL '7 days' GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"lineInterpolation": "smooth"}
        }
      }
    },
    {
      "title": "GPU Resource Consumption by Type",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT data->>'resource_type' AS resource_type, COUNT(*) AS count, SUM((data->>'amount')::numeric) AS total FROM events WHERE event_type IN ('ResourceConsumed', 'ResourceConsumedV2') AND occurred_at >= NOW() - INTERVAL '24 hours' GROUP BY resource_type ORDER BY total DESC",
          "format": "table"
        }
      ]
    },
    {
      "title": "Top Agents by TVS Contribution",
      "type": "table",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT aggregate_id AS agent, COUNT(*) AS leases, COALESCE(SUM((data->>'amount_micro_usdc')::numeric) / 1000000, SUM((data->>'amount')::numeric)) AS tvs, MAX(occurred_at) AS last_active FROM events WHERE event_type IN ('PaymentVerified', 'BillingSessionSettled') AND occurred_at >= NOW() - INTERVAL '7 days' GROUP BY aggregate_id ORDER BY tvs DESC LIMIT 20",
          "format": "table"
        }
      ]
    },
    {
      "title": "Kill-Switch Events Over Time",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT DATE_TRUNC('hour', occurred_at) AS time, COUNT(*) AS kill_switches FROM events WHERE data->>'kill_switch_triggered' = 'true' AND occurred_at >= NOW() - INTERVAL '7 days' GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"lineInterpolation": "smooth"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "title": "DePIN Provider Distribution",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "${datasource}",
          "rawSql": "SELECT DATE_TRUNC('hour', occurred_at) AS time, COUNT(*) FILTER (WHERE data->>'provider_id' LIKE '%io-net%') AS io_net, COUNT(*) FILTER (WHERE data->>'provider_id' LIKE '%render%') AS render, COUNT(*) FILTER (WHERE data->>'provider_id' LIKE '%akash%') AS akash FROM events WHERE event_type IN ('PaymentVerified', 'ResourceConsumedV2') AND occurred_at >= NOW() - INTERVAL '7 days' GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"lineInterpolation": "smooth"}
        }
      }
    }
  ]
}
