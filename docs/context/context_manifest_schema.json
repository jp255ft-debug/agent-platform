{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-platform.example.com/context-manifest-schema.json",
  "title": "Context Manifest Schema",
  "description": "Schema for validating context_manifest.json files. Used to ensure reproducibility of AI agent sessions.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version of this manifest (semver)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of session start",
      "format": "date-time",
      "examples": ["2026-06-10T14:30:00-03:00"]
    },
    "mode": {
      "type": "string",
      "description": "AI agent mode during this session",
      "enum": ["PLAN_MODE", "ACT_MODE"],
      "examples": ["ACT_MODE"]
    },
    "task_description": {
      "type": "string",
      "description": "Brief description of the task being executed",
      "minLength": 1,
      "maxLength": 500,
      "examples": ["Implement AgentDelegation.sol contract"]
    },
    "loaded_contexts": {
      "type": "array",
      "description": "List of context files loaded during this session",
      "items": {
        "type": "string",
        "pattern": "^\\.ai/|^docs/|^ARCHITECTURE\\.md$",
        "examples": [
          ".ai/AGENTS.md",
          ".ai/knowledge-base/solidity_patterns.md",
          "docs/adr/ADR-002-delegation-eip7702.md"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "generated_files": {
      "type": "array",
      "description": "List of files generated or modified during this session",
      "items": {
        "type": "string",
        "examples": [
          "contracts/src/AgentDelegation.sol",
          "contracts/test/AgentDelegation.t.sol"
        ]
      },
      "uniqueItems": true
    },
    "validation_results": {
      "type": "object",
      "description": "Results of validation checks run after code generation",
      "properties": {
        "passed": {
          "type": "integer",
          "description": "Number of validation checks passed",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "description": "Number of validation checks failed",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "description": "Number of warnings",
          "minimum": 0
        }
      },
      "required": ["passed", "failed", "warnings"],
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "timestamp",
    "mode",
    "task_description",
    "loaded_contexts",
    "generated_files",
    "validation_results"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "version": "1.0.0",
      "timestamp": "2026-06-10T14:30:00-03:00",
      "mode": "ACT_MODE",
      "task_description": "Implement AgentDelegation.sol contract",
      "loaded_contexts": [
        ".ai/AGENTS.md",
        ".ai/knowledge-base/solidity_patterns.md",
        ".ai/knowledge-base/architecture_patterns.md",
        "docs/adr/ADR-002-delegation-eip7702.md"
      ],
      "generated_files": [
        "contracts/src/AgentDelegation.sol",
        "contracts/test/AgentDelegation.t.sol"
      ],
      "validation_results": {
        "passed": 5,
        "failed": 0,
        "warnings": 1
      }
    }
  ]
}
