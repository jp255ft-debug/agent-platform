  "schema": "docs/context/context_manifest_schema.json",
  "fields": {
    "version": "Schema version of this manifest",
    "timestamp": "ISO 8601 timestamp of session start",
    "mode": "PLAN_MODE or ACT_MODE",
    "task_description": "Brief description of the task being executed",
    "loaded_contexts": [
      "List of context files loaded during this session"
    ],
    "generated_files": [
      "List of files generated or modified during this session"
    ],
    "validation_results": {
      "passed": "Number of validation checks passed",
      "failed": "Number of validation checks failed",
      "warnings": "Number of warnings"
    }
  },
